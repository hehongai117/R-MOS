# === 必填 (生产环境) ===
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/rmos
# 生产环境必须替换为强随机密钥（至少 32 字符）
# 生成命令: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=your-random-secret-key-here

# === 可选 ===
DEBUG=false
CORS_ORIGINS=["https://your-domain.com"]
ROBOT_MODE=simulation
LOG_LEVEL=INFO

# === LLM (不填则自动降级 Mock) ===
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
MINIMAX_API_KEY=
MINIMAX_GROUP_ID=
LLM_ENABLE_MOCK_FALLBACK=true
