# === 必填 (生产环境) ===
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/rmos
# 生产环境必须替换为强随机密钥（至少 32 字符）
# 生成命令: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=your-random-secret-key-here

# === 可选 ===
DEBUG=false
CORS_ORIGINS=["https://your-domain.com"]
ROBOT_MODE=simulation
LOG_LEVEL=INFO

# === LLM (不填则自动降级 Mock) ===
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
MINIMAX_API_KEY=
MINIMAX_GROUP_ID=
LLM_ENABLE_MOCK_FALLBACK=true

# ===== 存储后端 =====
# local: 本地磁盘(默认) / s3: S3 兼容对象存储(AWS S3/MinIO/阿里云 OSS)
STORAGE_BACKEND=local
# STORAGE_BACKEND=s3 时按需配置：
# S3_ENDPOINT_URL=http://localhost:9000        # MinIO/OSS endpoint；AWS 留空
# S3_PUBLIC_ENDPOINT_URL=http://localhost:9000 # 浏览器可达域名(presign 用)
# S3_BUCKET=rmos-assets
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# S3_REGION=us-east-1
