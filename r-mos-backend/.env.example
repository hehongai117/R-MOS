# R-MOS Backend 环境变量配置模板
# 复制此文件为 .env 并填写实际值

# 服务器配置
HOST=0.0.0.0
PORT=8000
DEBUG=True

# 数据库配置（PostgreSQL）
DATABASE_URL=postgresql+asyncpg://postgres:REPLACE_ME@localhost:5432/rmos_dev

# CORS配置（前端地址）
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# Adapter配置
ROBOT_ADAPTER_TYPE=mock
MOCK_JOINT_COUNT=10
MOCK_SIMULATION_SPEED=1.0
MOCK_BASE_TEMPERATURE=40.0

# WebSocket配置
WEBSOCKET_HEARTBEAT_INTERVAL=30
WEBSOCKET_PUSH_FREQUENCY=5

# 日志配置
LOG_LEVEL=INFO
